+def _start_web_key_subscriber(
+    kb: "KeyboardCommandState",
+    redis_host: str,
+    redis_port: int,
+    channel: str,
+) -> threading.Thread:
+    """Daemon thread: subscribe to Redis pub/sub `channel`, forward (event, token)
+    pairs to the keyboard state machine with source='web'. Bridge publishes
+    pickle.dumps(("press"|"release", token)) on this channel."""
+
+    def _run() -> None:
+        while True:
+            try:
+                client = redis.Redis(host=redis_host, port=int(redis_port), db=0)
+                pubsub = client.pubsub(ignore_subscribe_messages=True)
+                pubsub.subscribe(channel)
+                print(f"[web-keys] subscribed to redis channel '{channel}' on {redis_host}:{redis_port}", flush=True)
+                for msg in pubsub.listen():
+                    if msg.get("type") != "message":
+                        continue
+                    data = msg.get("data")
+                    if not data:
+                        continue
+                    try:
+                        event, token = pickle.loads(data)
+                    except Exception as e:
+                        print(f"[web-keys] bad payload: {e}", flush=True)
+                        continue
+                    token = str(token).lower()
+                    if event == "press":
+                        kb._handle_press_token(token, source="web")
+                    elif event == "release":
+                        kb._handle_release_token(token, source="web")
+            except Exception as e:
+                print(f"[web-keys] subscriber error: {e}; reconnecting in 1s", flush=True)
+                time.sleep(1.0)
+
+    t = threading.Thread(target=_run, name="web-keys-subscriber", daemon=True)
+    t.start()
+    return t
+
+
